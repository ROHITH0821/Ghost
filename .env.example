# Database (optional — SQLite for local dev; not used for OTP auth on Vercel)
DATABASE_URL="file:./prisma/dev.db"

# Auth — generate with: openssl rand -base64 32 (required in production)
AUTH_SECRET="your-secret-key-min-32-chars-long"

# Resend — https://resend.com/api-keys (required in production)
RESEND_API_KEY="re_xxxxxxxxxxxx"
RESEND_FROM_EMAIL="Ghost <info@yourdomain.com>"

# App URL (used in email links)
NEXT_PUBLIC_APP_URL="http://localhost:3000"
