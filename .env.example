# Database — Supabase Postgres.
# DATABASE_URL: pooled connection (pgBouncer, port 6543) used by the app at runtime.
# DIRECT_URL:   direct connection (port 5432) used for migrations / prisma db push.
DATABASE_URL="postgresql://postgres.<ref>:<password>@<region>.pooler.supabase.com:6543/postgres?pgbouncer=true"
DIRECT_URL="postgresql://postgres.<ref>:<password>@<region>.pooler.supabase.com:5432/postgres"

# Auth — generate with: openssl rand -base64 32
AUTH_SECRET="your-secret-key-min-32-chars-long"

# Resend — https://resend.com/api-keys
RESEND_API_KEY="re_xxxxxxxxxxxx"
RESEND_FROM_EMAIL="Ghost <onboarding@resend.dev>"

# App URL (used in email links)
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# GHOST engine — Claude API key (required to run real audits)
# https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY="sk-ant-..."

# Supabase Storage (PDF archive)
# Create a Storage bucket named `ghost-reports` (public).
SUPABASE_URL="https://<ref>.supabase.co"
# Server-only (never expose to browser)
SUPABASE_SERVICE_ROLE_KEY="your-service-role-key"
SUPABASE_PDF_BUCKET="ghost-reports"

# Optional engine overrides (see src/lib/ghost-engine/config.ts for all):
# GHOST_MODEL="claude-sonnet-4-6"        # personas + aggregation model
# GHOST_FLOW_MODEL="claude-haiku-4-5"    # cheaper model for flow analysis
# GHOST_MAX_FIXES=3                       # top leaks to generate fixes for
# GHOST_CRAWL_MAX_PAGES=8                 # pages crawled per site
# GHOST_PDF=0                             # set 0 to skip PDF generation
#
# NOTE: crawling/PDF need the Playwright browser once:
#   npx playwright install chromium
