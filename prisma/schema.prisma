generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  // Pooled connection (pgBouncer, port 6543) for the app at runtime.
  url       = env("DATABASE_URL")
  // Direct connection (port 5432) for migrations / `prisma db push`.
  directUrl = env("DIRECT_URL")
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  otpTokens OtpToken[]
  missions  Mission[]
}

model OtpToken {
  id        String   @id @default(cuid())
  email     String
  codeHash  String
  expiresAt DateTime
  used      Boolean  @default(false)
  createdAt DateTime @default(now())

  userId String?
  user   User?   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([email])
  @@index([expiresAt])
}

model Mission {
  id        String   @id
  url       String
  domain    String
  status    String   @default("running")
  // Live scan progress for polling across serverless instances.
  progress  Json?
  // The finished GhostReport, persisted so results survive restarts / are
  // retrievable across instances (not just from the in-memory cache).
  report    Json?
  pdfUrl        String?
  pdfUploadedAt DateTime?
  userId    String?
  user      User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
}
